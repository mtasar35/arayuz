# Bu dosyayı kopyalayıp `.env` yapın (gizli anahtarları repoya koymayın).
# Create React App: sadece REACT_APP_ ile başlayan değişkenler derlemeye girer.

# İsteğe bağlı: backend API kök adresi (sonunda / olmadan)
# Örnek: http://localhost:8000
REACT_APP_API_URL=

# İsteğe bağlı: appShell.js içindeki varsayılanları geçersiz kılar
REACT_APP_NAME=
REACT_APP_STORAGE_PREFIX=
# REACT_APP_LOGO_URL=
